# =============================================================================
# Copy this file to `.env` in the repo root. `.env` is gitignored — never commit secrets.
# Netlify Dev / `npm run dev:functions` loads `.env` for local serverless functions.
# On Netlify production, set the same keys in: Site settings → Environment variables.
# =============================================================================

# -----------------------------------------------------------------------------
# API keys — which one you need
# -----------------------------------------------------------------------------
# OPENAI_API_KEY
#   When: Generating agent (`generating-agent`) — default backend is OpenAI (gpt-5.4).
#   When: Remotion coding agent only if REMOTION_CODING_AGENT_PROVIDER=openai or ANTHROPIC_API_KEY is unset.
OPENAI_API_KEY=

# ANTHROPIC_API_KEY
#   When: Remotion coding agent (`remotion-coding-agent`) — defaults to Claude when this is set.
#   When: Generating agent only if you set GENERATING_AGENT_PROVIDER=anthropic (optional Claude path).
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Generating agent (`/.netlify/functions/generating-agent`)
# -----------------------------------------------------------------------------
# Default backend: OpenAI (gpt-5.4). Use Claude only when you opt in.
# GENERATING_AGENT_PROVIDER
#   Optional. `openai` (default) | `anthropic` — force backend.
# GENERATING_AGENT_MODEL
#   OpenAI model when using OpenAI (default in code: gpt-5.4).
#   Used for phase 1 only: ideas_md + prompt_md (tool loop, reads the site bundle).
# GENERATING_AGENT_VOICE_SOUND_MODEL
#   OpenAI model for phase 2 only: voice_md + sound_md (single JSON completion, no site tools).
#   Default in code: gpt-4o-mini — cheaper and gentler on RPM than the visual model.
# GENERATING_AGENT_ANTHROPIC_MODEL
#   Anthropic model when GENERATING_AGENT_PROVIDER=anthropic (default: claude-sonnet-4-6 — cheaper than Opus).
#   For max quality: claude-opus-4-6. For cheapest tests: claude-haiku-4-5.
# GENERATING_AGENT_ANTHROPIC_MAX_TOKENS
#   Optional. Max output tokens for Claude (clamped in code; default 64000).
# GENERATING_AGENT_MODEL=gpt-5.4
# GENERATING_AGENT_VOICE_SOUND_MODEL=gpt-4o-mini
# GENERATING_AGENT_ROUND_DELAY_MS
#   Optional delay (ms) between each tool-loop round and between OpenAI phases.
#   Default 0 (no delay). Set e.g. 3000 if you need to throttle RPM manually.
# GENERATING_AGENT_ROUND_DELAY_MS=0
# GENERATING_AGENT_ANTHROPIC_MODEL=claude-sonnet-4-6
# GENERATING_AGENT_ANTHROPIC_MAX_TOKENS=64000
# GENERATING_AGENT_PROVIDER=openai

# -----------------------------------------------------------------------------
# Remotion coding agent (`/.netlify/functions/remotion-coding-agent`)
# -----------------------------------------------------------------------------
# Default backend: Anthropic when ANTHROPIC_API_KEY is set; otherwise OpenAI.
# REMOTION_CODING_AGENT_PROVIDER
#   Optional. `anthropic` | `openai` — force which API (overrides auto-pick).
# REMOTION_CODING_AGENT_MODEL
#   OpenAI model id when using OpenAI (default: gpt-5.4).
# REMOTION_CODING_AGENT_ANTHROPIC_MODEL
#   Claude model when using Anthropic (default: claude-sonnet-4-6).
#   claude-opus-4-6 = max quality; claude-haiku-4-5 = cheapest for quick tests.
# REMOTION_CODING_AGENT_MAX_OUTPUT_TOKENS
#   Optional cap for completion size (long multi-file JSON). Anthropic path clamps to 128000.
# REMOTION_CODING_AGENT_MODEL=gpt-5.4
# REMOTION_CODING_AGENT_ANTHROPIC_MODEL=claude-sonnet-4-6
# REMOTION_CODING_AGENT_MAX_OUTPUT_TOKENS=120000
# REMOTION_CODING_AGENT_PROVIDER=anthropic

# -----------------------------------------------------------------------------
# Audio pipeline (post-render voiceover)
# -----------------------------------------------------------------------------
# If ELEVENLABS_API_KEY is set, voiceover uses ElevenLabs first (preferred, human-like voices).
# If a clip fails, OpenAI TTS is used for that clip when OPENAI_API_KEY is set.
# Set ELEVENLABS_NO_OPENAI_FALLBACK=1 to disable that fallback (fail the clip instead).
# If ELEVENLABS_API_KEY is unset, voiceover uses OpenAI speech when OPENAI_API_KEY is set.
#
# ELEVENLABS_API_KEY
#   ElevenLabs API key (https://elevenlabs.io → Profile / API keys).
# ELEVENLABS_API_KEY=
#
# ELEVENLABS_NO_OPENAI_FALLBACK
#   Set to 1 to never fall back to OpenAI when ElevenLabs fails (per clip).
# ELEVENLABS_NO_OPENAI_FALLBACK=0
#
# ELEVENLABS_VOICE_ID
#   Voice id from https://elevenlabs.io/app/voice-library (click a voice → id in URL or settings).
#   Default in code: Rachel (21m00Tcm4TlvDq8ikWAM).
# ELEVENLABS_VOICE_ID=
#
# ELEVENLABS_MODEL
#   Default: eleven_turbo_v2_5 (natural English). Use eleven_multilingual_v2 for non-English or if your account rejects turbo.
# ELEVENLABS_MODEL=eleven_turbo_v2_5
# ELEVENLABS_MODEL=eleven_multilingual_v2
#
# ELEVENLABS_SPEED
#   Optional. Speech speed 0.7–1.2 (e.g. 0.97 for slightly calmer). Omit to use ElevenLabs default.
# ELEVENLABS_SPEED=0.97
#
# ELEVENLABS_OUTPUT_FORMAT
#   Query param for the TTS API (codec_sample_rate_bitrate). Free tier: try mp3_22050_32 or mp3_44100_64 if 128 fails.
#   Default: mp3_44100_128
# ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
#
# Optional voice_settings overrides (defaults tuned for natural delivery; 0–1 except speaker boost):
# ELEVENLABS_STABILITY=0.36
# ELEVENLABS_SIMILARITY_BOOST=0.82
# ELEVENLABS_STYLE=0.36
# ELEVENLABS_USE_SPEAKER_BOOST=1   (set to 0 to disable)
#
# OPENAI_TTS_VOICE (when ElevenLabs is not used, or per-clip fallback after ElevenLabs errors)
#   Options: alloy, echo, fable, onyx, nova, shimmer. Default: alloy
# OPENAI_TTS_VOICE=alloy
#
# OPENAI_TTS_MODEL
#   tts-1 or tts-1-hd. Default: tts-1
# OPENAI_TTS_MODEL=tts-1
#
# Voice mux (post-render): avoid chopping narration when TTS is longer than the video
# VOICE_MUX_MIN_TAIL_SEC
#   Silence tail after the last speech + frame pad (seconds). Default: 0.95
# VOICE_MUX_FRAME_PAD_SEC
#   Small extra pad to beat container roundoff. Default: 0.12
# VOICE_MUX_AAC_BITRATE_K
#   AAC bitrate for muxed audio (kbps). Default: 192
# VOICE_MIX_END_PAD_SEC
#   Extra seconds after the last spoken clip when building the mixed WAV (avoids truncating long TTS). Default: 0.45
# VOICE_LINE_GAP_MS
#   Milliseconds between sequential VO lines. Default: 380
# VOICE_MUX_VIDEO_CRF
#   When the video must be extended (freeze last frame), libx264 CRF. Default: 18
# VOICE_MUX_MIN_TAIL_SEC=0.95

# -----------------------------------------------------------------------------
# Capture functions (local dev — rendered capture uses Puppeteer)
# -----------------------------------------------------------------------------
# PUPPETEER_EXECUTABLE_PATH
#   When: Local `capture-rendered` if Chromium isn’t found automatically.
#   Example (Linux): /usr/bin/chromium-browser or path from `which chromium`
# PUPPETEER_EXECUTABLE_PATH=

# CAPTURE_RENDERED_NAVIGATION_TIMEOUT_MS
#   Puppeteer `page.goto` max wait (ms). Default: 120000. Raise for slow sites; must stay under the Netlify function timeout for capture-rendered.
# CAPTURE_RENDERED_NAVIGATION_TIMEOUT_MS=120000
#
# CAPTURE_RENDERED_WAIT_UNTIL
#   Puppeteer waitUntil: networkidle2 (default), load, domcontentloaded, networkidle0.
#   Use `load` or `domcontentloaded` if the page never becomes “network idle” (analytics, websockets).
# CAPTURE_RENDERED_WAIT_UNTIL=networkidle2

# CAPTURE_CORS_ORIGIN
#   When: Locking CORS on capture endpoints to your dev origin instead of `*`.
#   Example: http://localhost:5173
# CAPTURE_CORS_ORIGIN=*
